# K8s Release Platform 环境变量配置

# 应用配置
APP_NAME="K8s Release Platform"
DEBUG=false
SECRET_KEY="your-secret-key-change-in-production"

# 数据库配置
DATABASE_URL="mysql+aiomysql://root:rootpass@localhost:3306/k8s_platform"

# Redis 配置
REDIS_URL="redis://localhost:6379/0"

# JWT 配置
JWT_SECRET="jwt-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# Harbor 镜像仓库配置（可选）
# 系统会自动从 Deployment 的镜像地址中提取 Harbor 地址
# 认证信息获取优先级：
# 1. 从 K8s Secret 自动获取（harbor-secret, registry-secret 等）
# 2. 使用以下配置的账号密码
HARBOR_URL="https://harbor.example.com"  # 默认 Harbor 地址（可选）
HARBOR_USERNAME="admin"  # Harbor 用户名（作为备选）
HARBOR_PASSWORD="Harbor12345"  # Harbor 密码（作为备选）

# K8s 配置
K8S_DEFAULT_TIMEOUT=300
K8S_ROLLING_UPDATE_TIMEOUT=600

# 加密配置 (用于加密 kubeconfig 等敏感信息)
# 可以使用: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""
